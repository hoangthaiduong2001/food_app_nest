# Database
DATABASE_URL="postgresql://user:password@localhost:5432/food_app"

# JWT
ACCESS_TOKEN_SECRET="your-access-secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="your-refresh-secret"
REFRESH_TOKEN_EXPIRES_IN="7d"

# App
NODE_ENV="development"
LOG_LEVEL="debug"
CORS_ORIGINS="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# AWS S3 (file upload)
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET_NAME="your-bucket"
S3_PUBLIC_URL="https://your-bucket.s3.amazonaws.com"

# Stripe (test mode — get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret — get from: stripe listen --forward-to localhost:3003/payment/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# AWS SES (email)
SES_REGION="ap-southeast-1"
SES_ACCESS_KEY="your-ses-access-key"
SES_SECRET_KEY="your-ses-secret-key"
SES_FROM_EMAIL="noreply@yourdomain.com"
