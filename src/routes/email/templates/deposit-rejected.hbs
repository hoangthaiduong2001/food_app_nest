<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Deposit Rejected</title>
  <style>
    body { font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #ef4444; color: white; padding: 20px; border-radius: 8px 8px 0 0; }
    .content { border: 1px solid #eee; padding: 20px; }
    .reason { background: #fef2f2; border-left: 4px solid #ef4444; padding: 12px; margin: 12px 0; }
    .footer { color: #999; font-size: 12px; margin-top: 20px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>Deposit Request Rejected</h1>
  </div>
  <div class="content">
    <p>Hi <strong>{{customerName}}</strong>,</p>
    <p>Unfortunately, your deposit request #{{requestId}} for <strong>{{amount}} {{currency}}</strong> has been rejected.</p>
    {{#if rejectReason}}
    <div class="reason">
      <strong>Reason:</strong> {{rejectReason}}
    </div>
    {{/if}}
    <p>Please contact support if you believe this is an error.</p>
  </div>
  <div class="footer">
    <p>Thank you for your understanding.</p>
  </div>
</body>
</html>
